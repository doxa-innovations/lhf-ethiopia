# Optional alternative to the nginx config in DEPLOYMENT.md.
# Caddy auto-issues Let's Encrypt certs for the domains below.
# Assumes `next start` is running on port 3000 on the same host
# (e.g. under pm2 or systemd). If you prefer nginx, ignore this file.

{
    email info@lhfethiopia.org
}

www.lhfethiopia.org {
    redir https://lhfethiopia.org{uri} permanent
}

lhfethiopia.org {
    encode zstd gzip

    reverse_proxy 127.0.0.1:3000

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "SAMEORIGIN"
        Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "geolocation=(), microphone=(), camera=()"
    }

    log {
        output stdout
        format console
    }
}
