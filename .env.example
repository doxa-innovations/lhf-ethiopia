# LHF Ethiopia — CMS environment variables.
# Copy to .env (dev) or .env.production (prod), fill, and commit nothing.

# Site
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Payload secret — any 32+ char random string. Rotate ONLY by also issuing
# new admin sessions; existing JWTs invalidate on rotation.
PAYLOAD_SECRET=replace-me-with-openssl-rand-base64-32

# Database
# Dev (no DB infra needed): SQLite file in repo root.
DATABASE_URI=file:./payload.db
# Prod: a Postgres connection string. The adapter switches automatically.
# DATABASE_URI=postgres://payload:password@localhost:5432/payload

# Media (production only — leave blank in dev to use public/uploads/).
R2_BUCKET=
R2_ENDPOINT=
R2_REGION=auto
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_URL=
